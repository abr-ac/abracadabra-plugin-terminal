{
  "name": "abracadabra-plugin-terminal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared collaborative terminal page type for CouShell — xterm.js renderer + a process-capable serverRunner that bridges a PTY over the hybrid transport (awareness output + doc input/scrollback).",
  "scripts": {
    "build": "vite build && vite build --config vite.config.server.ts",
    "build:client": "vite build",
    "build:server": "vite build --config vite.config.server.ts",
    "typecheck": "vue-tsc --noEmit",
    "pack": "abra-plugin pack"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@abraca/dabra": "^2.60.0",
    "@abraca/plugin": "^2.60.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0",
    "yjs": "^13.6.30"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "yjs": "^13.6.0"
  },
  "pnpm": {
    "overrides": {
      "@codemirror/state": "6.6.0",
      "@codemirror/view": "6.43.0",
      "@tiptap/core": "3.23.5",
      "@tiptap/pm": "3.23.5",
      "@tiptap/vue-3": "3.23.5",
      "@tiptap/y-tiptap": "3.0.3",
      "highlight.js": "11.11.1",
      "lowlight": "3.3.0",
      "prosemirror-commands": "1.7.1",
      "prosemirror-gapcursor": "1.4.1",
      "prosemirror-history": "1.5.0",
      "prosemirror-inputrules": "1.5.1",
      "prosemirror-keymap": "1.2.3",
      "prosemirror-model": "1.25.7",
      "prosemirror-state": "1.4.4",
      "prosemirror-transform": "1.12.0",
      "prosemirror-view": "1.41.8",
      "vue": "3.5.34",
      "y-protocols": "1.0.7",
      "yjs": "13.6.30"
    }
  }
}
